generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model User {
  id    String @id @default(cuid())
  email String @unique
  role  Role   @default(ADMIN)

  // Generic person info (optional)
  firstName     String?
  lastName      String?
  phone         String?
  image         String?
  lastLoginAt   DateTime?
  emailVerified DateTime?
  // Flexible user-specific data
  metadata      Json? // ← Future-proof

  accounts Account[]
  sessions Session[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Log {
  id        String   @id @default(cuid())
  action    String // "CONTACT_FORM_SUBMITTED", "USER_LOGIN", "SUBMISSION_STATUS_CHANGED"
  message   String // "John Doe filled out a contact form"
  entity    String? // "ContactSubmission", "User"
  entityId  String? // the cuid of the related record
  metadata  Json? // { device: "Mobile", browser: "Safari", status: { from: "new", to: "contacted" } }
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([action])
  @@index([entity, entityId])
  @@index([createdAt])
}

model ContactSubmission {
  id           String   @id @default(cuid())
  firstName    String
  lastName     String
  email        String?
  phoneNumber  String?
  propertyType String? // buy, sell, both
  priceRange   String? // budget range
  timeframe    String? // when looking to buy/sell
  subject      String
  message      String
  status       String   @default("new") // new, contacted, closed
  source       String   @default("contact-form")
  ipAddress    String? // spam protection / audit trail
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([email])
  @@index([status])
  @@index([createdAt])
}

enum Role {
  SUPER_USER
  ADMIN
}
